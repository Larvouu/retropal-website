---
/**
 * CRT-style bezel wrapper. Use to frame screenshots or pixel-art blocks.
 *   <CRTFrame>...content...</CRTFrame>
 */

export interface Props {
  /** Aspect ratio of the inner viewing area, e.g. "3 / 2", "16 / 9" */
  aspectRatio?: string;
  /** Inner background color (the "screen") */
  screenColor?: string;
}

const { aspectRatio = "4 / 3", screenColor = "#0F380F" } = Astro.props;
---

<div class="crt" style={`--aspect: ${aspectRatio}; --screen: ${screenColor}`}>
  <div class="crt-bezel">
    <div class="crt-screen scanlines">
      <div class="crt-content">
        <slot />
      </div>
      <div class="crt-glare" aria-hidden="true"></div>
    </div>
  </div>
  <div class="crt-base" aria-hidden="true"></div>
</div>

<style>
  .crt {
    display: inline-block;
    max-width: 100%;
  }

  .crt-bezel {
    background: linear-gradient(180deg, #2a2520 0%, #1a1814 80%, #0d0c0a 100%);
    border: 2px solid #1a1814;
    padding: 1.25rem 1.25rem 1.5rem;
    border-radius: 14px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 12px 24px rgba(15, 56, 15, 0.18),
      0 4px 8px rgba(26, 24, 20, 0.2);
    position: relative;
  }

  .crt-screen {
    aspect-ratio: var(--aspect);
    background: var(--screen);
    border-radius: 8px;
    box-shadow:
      inset 0 0 0 2px #0a0908,
      inset 0 0 24px rgba(0, 0, 0, 0.45),
      inset 0 0 80px rgba(0, 0, 0, 0.35);
    overflow: hidden;
    position: relative;
  }

  .crt-content {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: var(--accent);
    font-family: var(--font-display);
    text-shadow: 0 0 6px rgba(118, 37, 196, 0.55);
  }

  .crt-glare {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 90% 35% at 25% 12%,
        rgba(255, 255, 255, 0.12),
        transparent 70%
      );
  }

  .crt-base {
    height: 8px;
    width: 75%;
    margin: -4px auto 0;
    background: #1a1814;
    border-radius: 0 0 8px 8px;
    box-shadow: 0 6px 12px rgba(15, 56, 15, 0.18);
  }
</style>
