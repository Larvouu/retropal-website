---
import type { Locale } from "../i18n/ui";
import { getUi } from "../i18n/ui";
import LangSwitch from "./LangSwitch.astro";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ui = getUi(locale);

const links = locale === "fr"
  ? [
      { href: "/confidentialite", label: ui.footer.privacy },
      { href: "/conditions", label: ui.footer.terms },
      { href: "/mentions-legales", label: ui.footer.legal },
      { href: "/support", label: ui.footer.support },
    ]
  : [
      { href: "/en/privacy", label: ui.footer.privacy },
      { href: "/en/terms", label: ui.footer.terms },
      { href: "/en/legal", label: ui.footer.legal },
      { href: "/en/support", label: ui.footer.support },
    ];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="dotted" aria-hidden="true"></div>

  <div class="page-shell footer-inner">
    <div class="footer-brand">
      <div class="footer-wordmark">Retro Pal</div>
      <p class="footer-tag">
        {ui.footer.builtBy} {ui.footer.openSource}
      </p>
    </div>

    <nav class="footer-links" aria-label={ui.footer.legalHeading}>
      <span class="footer-heading">{ui.footer.legalHeading}</span>
      <ul>
        {links.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="footer-meta">
      <p class="footer-attrib">{ui.footer.poweredBy}</p>
      <p class="footer-copyright">
        © {year} Retro Pal
      </p>
      <div class="footer-lang">
        <LangSwitch locale={locale} />
      </div>
    </div>
  </div>

  <!-- Decorative bottom strip: tiny pixel pattern -->
  <div class="footer-decor" aria-hidden="true"></div>
</footer>

<style>
  .footer {
    margin-top: 4rem;
    background: var(--paper);
    color: var(--ink-soft);
    font-size: 0.875rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1.4fr;
    gap: 2.5rem;
    padding-block: 3rem 2rem;
    align-items: start;
  }

  .footer-wordmark {
    font-family: var(--font-display);
    font-size: 1.875rem;
    line-height: 1;
    color: var(--ink);
    letter-spacing: 0.015em;
  }

  .footer-tag {
    margin-top: 0.6rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--ink-soft);
    max-width: 28ch;
  }

  .footer-heading {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 0.6rem;
  }

  .footer-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer-links a {
    color: var(--ink);
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
    transition: border-color 120ms ease;
  }

  .footer-links a:hover {
    border-color: var(--gb-green);
  }

  .footer-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-family: var(--font-body);
  }

  .footer-attrib {
    font-size: 0.8125rem;
    color: var(--ink-soft);
    max-width: 38ch;
  }

  .footer-copyright {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    color: var(--ink-faint);
    text-transform: uppercase;
  }

  .footer-lang {
    margin-top: 0.5rem;
  }

  /* Decorative bottom strip — Game Boy palette mini-stripe */
  .footer-decor {
    height: 6px;
    background: linear-gradient(
      to right,
      #0f380f 0%,
      #0f380f 25%,
      #306230 25%,
      #306230 50%,
      #8bac0f 50%,
      #8bac0f 75%,
      #9bbc0f 75%,
      #9bbc0f 100%
    );
    image-rendering: pixelated;
  }

  @media (max-width: 760px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }
</style>
