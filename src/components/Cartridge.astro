---
/**
 * Hero centerpiece: a stylized pixel-art Game Boy Advance-style cartridge with
 * "RETRO PAL" label. Entirely inline SVG — no external assets.
 *
 * Sized to fill its container (preserveAspectRatio="xMidYMid meet").
 */

export interface Props {
  /** Optional tilt in degrees applied to the wrapper */
  tilt?: number;
  /** Color of the cartridge plastic */
  shellColor?: string;
}

const { tilt = -3, shellColor = "#1E1A3B" } = Astro.props;
---

<div class="cart-wrap" style={`--tilt: ${tilt}deg`}>
  <div class="cart-shadow" aria-hidden="true"></div>
  <svg
    class="cart-svg"
    viewBox="0 0 240 320"
    width="240"
    height="320"
    role="img"
    aria-label="Cartouche Retro Pal"
    shape-rendering="crispEdges"
  >
    <!-- Outer shell: notched-top cartridge silhouette -->
    <!-- Shell uses 8-px grid for that hand-drawn pixel feel -->
    <defs>
      <pattern id="halftone" width="6" height="6" patternUnits="userSpaceOnUse">
        <circle cx="1" cy="1" r="0.75" fill="rgba(255,255,255,0.06)" />
      </pattern>
      <pattern id="labelGrain" width="3" height="3" patternUnits="userSpaceOnUse">
        <rect width="3" height="3" fill="#DFF9FB" />
        <rect x="0" y="0" width="1" height="1" fill="#B0E5EA" />
      </pattern>
    </defs>

    <!-- Shell body (notched top) -->
    <path
      d={[
        "M 24 16",
        "L 80 16",
        "L 80 32",
        "L 160 32",
        "L 160 16",
        "L 216 16",
        "L 216 296",
        "L 24 296",
        "Z",
      ].join(" ")}
      fill={shellColor}
    />

    <!-- Shell inner shadow (left side) -->
    <rect x="24" y="16" width="6" height="280" fill="rgba(255,255,255,0.06)" />
    <rect x="210" y="16" width="6" height="280" fill="rgba(0,0,0,0.25)" />
    <rect x="24" y="290" width="192" height="6" fill="rgba(0,0,0,0.3)" />

    <!-- Halftone texture on shell -->
    <path
      d={[
        "M 24 16",
        "L 80 16",
        "L 80 32",
        "L 160 32",
        "L 160 16",
        "L 216 16",
        "L 216 296",
        "L 24 296",
        "Z",
      ].join(" ")}
      fill="url(#halftone)"
    />

    <!-- Grip ridges near top -->
    <g fill="rgba(255,255,255,0.08)">
      <rect x="36" y="44" width="168" height="2" />
      <rect x="36" y="50" width="168" height="2" />
      <rect x="36" y="56" width="168" height="2" />
    </g>

    <!-- Label paper -->
    <rect x="40" y="76" width="160" height="200" fill="url(#labelGrain)" />
    <rect
      x="40"
      y="76"
      width="160"
      height="200"
      fill="none"
      stroke="#1E1A3B"
      stroke-width="2"
    />

    <!-- Label inner border (double-line magazine style) -->
    <rect
      x="46"
      y="82"
      width="148"
      height="188"
      fill="none"
      stroke="#1E1A3B"
      stroke-width="1"
    />

    <!-- Label top stripe -->
    <rect x="40" y="76" width="160" height="14" fill="#7625C4" />

    <!-- Label brand text (top stripe) -->
    <text
      x="120"
      y="86"
      text-anchor="middle"
      font-family="VT323, monospace"
      font-size="14"
      fill="#DFF9FB"
      letter-spacing="2"
    >
      RETRO PAL
    </text>

    <!-- App icon as the cartridge "cover art" — replaces the RP monogram -->
    <g>
      <!-- Soft inner frame to make the icon read like a sticker -->
      <rect
        x="65"
        y="100"
        width="110"
        height="110"
        fill="#1E1A3B"
      />
      <image
        href="/app-icon.png"
        x="67"
        y="102"
        width="106"
        height="106"
        preserveAspectRatio="xMidYMid slice"
      />
      <!-- Corner pixel marks for retro sticker feel -->
      <rect x="64" y="99" width="3" height="3" fill="#1E1A3B" />
      <rect x="173" y="99" width="3" height="3" fill="#1E1A3B" />
      <rect x="64" y="208" width="3" height="3" fill="#1E1A3B" />
      <rect x="173" y="208" width="3" height="3" fill="#1E1A3B" />
    </g>

    <!-- Subtitle on the label (tightened so it stays fully inside the label width) -->
    <text
      x="120"
      y="228"
      text-anchor="middle"
      font-family="VT323, monospace"
      font-size="14"
      fill="#1E1A3B"
      letter-spacing="1.2"
    >
      GBA · GB · GBC · DS
    </text>

    <!-- Small star burst — "TESTÉ ★★★★★" badge -->
    <g transform="translate(120, 250)">
      <text
        text-anchor="middle"
        font-family="VT323, monospace"
        font-size="13"
        fill="#1E1A3B"
        letter-spacing="0.8"
      >
        TESTÉ ★★★★★
      </text>
    </g>

    <!-- Label bottom stripe -->
    <rect x="40" y="262" width="160" height="14" fill="#7625C4" />

    <!-- Contact pins illusion (bottom rectangles) -->
    <g fill="rgba(0,0,0,0.4)">
      <rect x="56" y="298" width="128" height="6" />
    </g>
  </svg>
</div>

<style>
  .cart-wrap {
    position: relative;
    display: inline-block;
    transform: rotate(var(--tilt, -3deg));
    filter: drop-shadow(8px 10px 0 rgba(81, 24, 138, 0.32));
  }

  .cart-shadow {
    position: absolute;
    inset: 14px -10px -14px 10px;
    background: rgba(26, 24, 20, 0.08);
    z-index: -1;
    border-radius: 4px;
  }

  .cart-svg {
    display: block;
    width: clamp(280px, 42vw, 520px);
    height: auto;
  }

  @media (prefers-reduced-motion: no-preference) {
    .cart-wrap {
      animation: cart-drop 800ms cubic-bezier(0.2, 0.7, 0.2, 1.1) both;
    }

    @keyframes cart-drop {
      0% {
        opacity: 0;
        transform: translateY(-24px) rotate(calc(var(--tilt, -3deg) - 6deg));
      }
      60% {
        transform: translateY(4px) rotate(calc(var(--tilt, -3deg) + 1deg));
      }
      100% {
        opacity: 1;
        transform: translateY(0) rotate(var(--tilt, -3deg));
      }
    }
  }
</style>
