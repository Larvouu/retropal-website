---
/**
 * Top-of-page strip evoking a 1990s gaming magazine cover:
 *   left: ISSUE 01 / VOL. 01 / MAI 2026
 *   center: scrolling ticker with rotating cover lines
 *   right: tiny barcode-style mark
 *
 * Locale-aware: French and English versions render different ticker text.
 */
import type { Locale } from "../i18n/ui";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const tickerFR = [
  "★ ÉDITION SPÉCIALE ★",
  "BÊTA PRIVÉE 2026",
  "★ FAIT EN FRANCE",
  "ZÉRO TRACKING ★",
  "OPEN SOURCE",
  "★ UN SEUL ACHAT, POUR TOUJOURS ★",
  "GBA · GB · GBC · DS",
  "★",
];

const tickerEN = [
  "★ SPECIAL EDITION ★",
  "PRIVATE BETA 2026",
  "★ MADE IN FRANCE",
  "ZERO TRACKING ★",
  "OPEN SOURCE",
  "★ ONE PURCHASE, FOREVER ★",
  "GBA · GB · GBC · DS",
  "★",
];

const ticker = locale === "fr" ? tickerFR : tickerEN;
---

<aside class="masthead" aria-hidden="true">
  <div class="page-shell masthead-inner">
    <span class="masthead-ticker">
      <span class="ticker-track">
        {/* Duplicate the items so the marquee loop is seamless */}
        {[...ticker, ...ticker, ...ticker, ...ticker].map((t) => (
          <span class="ticker-item">{t}</span>
        ))}
      </span>
    </span>
  </div>
</aside>

<style>
  .masthead {
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border-bottom: 2px solid var(--accent);
    overflow: hidden;
  }

  .masthead-inner {
    display: block;
    padding-block: 0.55rem;
    line-height: 1;
  }

  /* Ticker: marquee-style horizontal scroll, CSS only */
  .masthead-ticker {
    display: block;
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(
      to right,
      transparent 0,
      black 4%,
      black 96%,
      transparent 100%
    );
  }

  .ticker-track {
    display: inline-flex;
    gap: 1.5rem;
    white-space: nowrap;
    animation: ticker-scroll 38s linear infinite;
    will-change: transform;
  }

  .ticker-item {
    color: var(--paper);
    opacity: 0.9;
  }

  .ticker-item:nth-child(odd) {
    color: var(--accent);
  }

  @keyframes ticker-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
  }
</style>
