---
/**
 * Top-of-page strip evoking a 1990s gaming magazine cover:
 *   left: ISSUE 01 / VOL. 01 / MAI 2026
 *   center: scrolling ticker with rotating cover lines
 *   right: tiny barcode-style mark
 *
 * Locale-aware: French and English versions render different ticker text.
 */
import type { Locale } from "../i18n/ui";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const tickerFR = [
  "★ ÉDITION SPÉCIALE ★",
  "BÊTA PRIVÉE 2026",
  "★ FAIT EN FRANCE",
  "ZÉRO TRACKING ★",
  "OPEN SOURCE",
  "★ UN SEUL ACHAT, POUR TOUJOURS ★",
  "GBA · GB · GBC · DS",
  "★",
];

const tickerEN = [
  "★ SPECIAL EDITION ★",
  "PRIVATE BETA 2026",
  "★ MADE IN FRANCE",
  "ZERO TRACKING ★",
  "OPEN SOURCE",
  "★ ONE PURCHASE, FOREVER ★",
  "GBA · GB · GBC · DS",
  "★",
];

const ticker = locale === "fr" ? tickerFR : tickerEN;
const issueLabel = locale === "fr" ? "ISSUE" : "ISSUE";
const volLabel = locale === "fr" ? "VOL." : "VOL.";
const monthLabel = locale === "fr" ? "MAI 2026" : "MAY 2026";
---

<aside class="masthead" aria-hidden="true">
  <div class="page-shell masthead-inner">
    <span class="masthead-left">
      <span class="masthead-issue">{issueLabel} <strong>01</strong></span>
      <span class="masthead-sep">·</span>
      <span class="masthead-vol">{volLabel} 01</span>
      <span class="masthead-sep">·</span>
      <span class="masthead-date">{monthLabel}</span>
    </span>

    <span class="masthead-ticker">
      <span class="ticker-track">
        {/* Duplicate the items so the marquee loop is seamless */}
        {[...ticker, ...ticker, ...ticker, ...ticker].map((t) => (
          <span class="ticker-item">{t}</span>
        ))}
      </span>
    </span>

    <span class="masthead-right">
      <span class="masthead-barcode" aria-hidden="true">
        {/* Pseudo-barcode: 12 randomized but fixed-width vertical bars */}
        <span class="bar bar-1"></span>
        <span class="bar bar-2"></span>
        <span class="bar bar-1"></span>
        <span class="bar bar-3"></span>
        <span class="bar bar-1"></span>
        <span class="bar bar-2"></span>
        <span class="bar bar-3"></span>
        <span class="bar bar-1"></span>
        <span class="bar bar-2"></span>
        <span class="bar bar-1"></span>
        <span class="bar bar-3"></span>
        <span class="bar bar-1"></span>
      </span>
      <span class="masthead-price">N° 01</span>
    </span>
  </div>
</aside>

<style>
  .masthead {
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border-bottom: 2px solid var(--accent);
    overflow: hidden;
  }

  .masthead-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.25rem;
    align-items: center;
    padding-block: 0.55rem;
    line-height: 1;
  }

  .masthead-left,
  .masthead-right {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    white-space: nowrap;
  }

  .masthead-issue strong {
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.1em;
  }

  .masthead-sep {
    color: var(--accent);
    opacity: 0.6;
  }

  /* Ticker: marquee-style horizontal scroll, CSS only */
  .masthead-ticker {
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(
      to right,
      transparent 0,
      black 6%,
      black 94%,
      transparent 100%
    );
  }

  .ticker-track {
    display: inline-flex;
    gap: 1.5rem;
    white-space: nowrap;
    animation: ticker-scroll 38s linear infinite;
    will-change: transform;
  }

  .ticker-item {
    color: var(--paper);
    opacity: 0.9;
  }

  .ticker-item:nth-child(odd) {
    color: var(--accent);
  }

  @keyframes ticker-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  /* Barcode pseudo-element */
  .masthead-barcode {
    display: inline-flex;
    align-items: center;
    gap: 1px;
    height: 12px;
    padding: 0 2px;
    background: var(--paper);
    border: 1px solid var(--paper);
  }

  .bar {
    display: inline-block;
    height: 100%;
    background: var(--ink);
  }

  .bar-1 {
    width: 1px;
  }
  .bar-2 {
    width: 2px;
  }
  .bar-3 {
    width: 3px;
  }

  .masthead-price {
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.1em;
  }

  @media (max-width: 760px) {
    .masthead-inner {
      grid-template-columns: auto 1fr;
      gap: 0.85rem;
    }
    .masthead-right {
      display: none;
    }
    .masthead-left {
      font-size: 0.65rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
  }
</style>
