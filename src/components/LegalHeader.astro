---
export interface Props {
  /** Eyebrow label, e.g. "POLITIQUE DE CONFIDENTIALITÉ" */
  kicker: string;
  /** Main title */
  title: string;
  /** Optional last-updated date, displayed as italic small caption */
  updated?: string;
  /** Optional intro paragraph */
  intro?: string;
}

const { kicker, title, updated, intro } = Astro.props;
---

<header class="legal-header">
  <span class="legal-kicker">{kicker}</span>
  <h1 class="legal-title">{title}</h1>
  {updated && <p class="legal-updated">{updated}</p>}
  {intro && <p class="legal-intro">{intro}</p>}
</header>

<style>
  .legal-header {
    padding-block: clamp(2.5rem, 5vw, 4rem) 1.5rem;
    border-bottom: 1px dashed var(--rule);
    margin-bottom: 2rem;
  }

  .legal-kicker {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent-dk);
    margin-bottom: 1rem;
    position: relative;
    padding-left: 1.25rem;
  }

  .legal-kicker::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 0.85rem;
    height: 1px;
    background: var(--accent);
    transform: translateY(-50%);
  }

  .legal-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw + 0.5rem, 4rem);
    line-height: 1;
    color: var(--ink);
    margin-bottom: 0.8rem;
  }

  .legal-updated {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .legal-intro {
    margin-top: 1.5rem;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.125rem;
    color: var(--ink-soft);
    max-width: 60ch;
    line-height: 1.55;
  }
</style>
