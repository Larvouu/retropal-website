---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionCounter from "../../components/SectionCounter.astro";
import PixelDivider from "../../components/PixelDivider.astro";
import Cartridge from "../../components/Cartridge.astro";
import ConsoleIcon from "../../components/ConsoleIcon.astro";
import AppStoreBadge from "../../components/AppStoreBadge.astro";
import { SUPPORT_EMAIL } from "../../i18n/ui";

const features = [
  {
    num: "01",
    title: "Native emulation",
    body:
      "GBA, Game Boy, Game Boy Color and Nintendo DS, powered by mGBA and melonDS. 60 frames per second, Metal acceleration, stereo audio.",
  },
  {
    num: "02",
    title: "Smart saves",
    body:
      "Five save state slots (two free), preview images, automatic background save. You always pick up exactly where you left off.",
  },
  {
    num: "03",
    title: "30-second rewind",
    body:
      "Made a mistake in a boss fight? Rewind up to thirty seconds (Pro). Five seconds free. The fastest way to avoid the game-over screen.",
  },
  {
    num: "04",
    title: "Speed 0.25× to 4×",
    body:
      "Slow it down for tough sections, turbo through grinds. Your call. 1× and 1.5× free, everything else with Pro.",
  },
  {
    num: "05",
    title: "Cheat codes",
    body:
      "GameShark, CodeBreaker, Action Replay, Action Replay DS. Named cheats, individual toggles, automatic backup before activation.",
  },
  {
    num: "06",
    title: "Custom controls",
    body:
      "Drag the D-pad, the buttons, adjust opacity and size. Up to three presets per system. Your hands, your layout.",
  },
  {
    num: "07",
    title: "Shareable screenshots",
    body:
      "Auto-generated share card with the game title, your cumulative playtime and a player tier badge. Pretty, instant, ready for Instagram.",
  },
  {
    num: "08",
    title: "Fully offline",
    body:
      "No connection required to play. Your ROMs, your saves, your games stay on your iPhone. Forever.",
  },
  {
    num: "09",
    title: "Ten European languages",
    body:
      "French, English, German, Spanish, Italian, Dutch, Polish, Portuguese, Swedish, Romanian. Localized by a human, not a machine.",
  },
];

const proPerks = [
  "All speeds: 0.25×, 0.5×, 2×, 3×, 4×",
  "Five save slots (up from two)",
  "Thirty-second rewind (GBA / GB / GBC)",
  "Unlimited cheat codes",
  "Custom control layouts, up to three presets",
];
---

<BaseLayout title="Retro Pal" isHome={true}>
  {/* ============================================================
       Hero — magazine cover spread
       ============================================================ */}
  <section class="hero scanlines" id="hero">
    <div class="hero-halftone" aria-hidden="true"></div>

    <div class="page-shell hero-inner">
      <div class="hero-content">
        <div class="hero-eyebrow rise rise-d1">
          <span class="kicker hero-cover-story">★ Cover Story</span>
          <span class="tape">Private beta · 2026</span>
        </div>

        <h1 class="hero-title rise rise-d2">
          <span class="hero-title-line">Retro</span>
          <span class="hero-title-line hero-title-emph">Pal</span>
        </h1>

        <p class="hero-sub rise rise-d3">The console you grew up with. Now in your pocket.</p>

        <p class="hero-lead lead rise rise-d4">
          Play your <strong>GBA</strong>, <strong>Game Boy</strong>,
          <strong>Game Boy Color</strong> and <strong>Nintendo DS</strong> games on iPhone.
          No ads, no tracking, no required subscription.
          <em>Forever.</em>
        </p>

        <div class="hero-cta rise rise-d5">
          <AppStoreBadge locale="en" />
          <a href="#features" class="hero-secondary">See features →</a>
        </div>

        <p class="hero-nameplate rise rise-d5">
          <span>Made in France</span>
          <span class="sep">·</span>
          <span>Zero tracking</span>
          <span class="sep">·</span>
          <span>Open source</span>
        </p>
      </div>

      <div class="hero-art" aria-hidden="true">
        <div class="hero-sticker rise rise-d4">
          <span class="hero-sticker-top">★ Exclusive</span>
          <span class="hero-sticker-big">№01</span>
          <span class="hero-sticker-bot">2026</span>
        </div>

        <Cartridge tilt={-4} />

        <div class="hero-art-grid"></div>

        <span class="hero-callout cb-1">
          <span class="cb-arrow">→</span>
          <span class="cb-text">Four consoles<br />in one app</span>
        </span>
        <span class="hero-callout cb-2">
          <span class="cb-text">30-second<br />rewind</span>
          <span class="cb-arrow">←</span>
        </span>
        <span class="hero-callout cb-3">
          <span class="cb-arrow">↗</span>
          <span class="cb-text">No ads<br />no tracking</span>
        </span>
      </div>
    </div>

    <div class="hero-bottom-rule" aria-hidden="true"></div>
  </section>

  {/* ============================================================
       Anti-feature manifesto — editorial column with REJECTED stamps
       ============================================================ */}
  <section class="section anti" id="anti">
    <div class="anti-tape" aria-hidden="true"></div>
    <div class="page-shell">
      <SectionCounter index={1} total={6} label="From the editor" />

      <div class="anti-grid">
        <div class="anti-head-wrap">
          <h2 class="display-h2 anti-head">
            Buy it once.<br />Play it forever.
          </h2>
          <p class="anti-sub">
            Three things you'll never find in Retro Pal.
            That's the editor's column this month.
          </p>
        </div>

        <ul class="anti-list" aria-label="What's not in Retro Pal">
          <li class="anti-item">
            <span class="anti-row">
              <span class="anti-strike">Ads</span>
              <span class="anti-stamp" aria-hidden="true">Rejected</span>
            </span>
            <span class="anti-note">Never. Not even a "non-intrusive" banner.</span>
          </li>
          <li class="anti-item">
            <span class="anti-row">
              <span class="anti-strike">Data collection</span>
              <span class="anti-stamp anti-stamp-2" aria-hidden="true">Rejected</span>
            </span>
            <span class="anti-note">No analytics. No cookies. No identifiers.</span>
          </li>
          <li class="anti-item">
            <span class="anti-row">
              <span class="anti-strike">Required subscription</span>
              <span class="anti-stamp anti-stamp-3" aria-hidden="true">Rejected</span>
            </span>
            <span class="anti-note">$4.99 once, forever. A subscription exists, but it's optional.</span>
          </li>
        </ul>

        <p class="anti-foot">
          We sell an app. We don't sell <em>you</em>.
          <span class="anti-sign">— The editor, Antoine</span>
        </p>
      </div>
    </div>
  </section>

  {/* ============================================================
       Systems supported
       ============================================================ */}
  <section class="section systems">
    <div class="page-shell">
      <SectionCounter index={2} total={6} label="Four consoles" />

      <h2 class="display-h2 systems-head">
        The full Nintendo portable retro catalog.
      </h2>
      <p class="lead systems-lead">
        One emulator, four generations. From the gray brick of 1989 to the dual-screen of 2004.
      </p>

      <div class="systems-grid">
        <ConsoleIcon system="gb" />
        <ConsoleIcon system="gbc" />
        <ConsoleIcon system="gba" />
        <ConsoleIcon system="nds" />
      </div>

      <PixelDivider variant="blocks" />
    </div>
  </section>

  {/* ============================================================
       Features grid (magazine-style)
       ============================================================ */}
  <section class="section features" id="features">
    <div class="page-shell">
      <SectionCounter index={3} total={6} label="Features" />

      <h2 class="display-h2 feat-head">
        Everything a serious emulator should do.<br />
        <span class="feat-head-soft">And nothing it shouldn't.</span>
      </h2>

      <div class="feat-grid">
        {features.map((f) => (
          <article class="feat-card">
            <span class="feat-num">{f.num}</span>
            <h3 class="feat-title">{f.title}</h3>
            <p class="feat-body">{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ============================================================
       Pro pricing block
       ============================================================ */}
  <section class="section pro" id="pro">
    <div class="page-shell pro-shell">
      <SectionCounter index={4} total={6} label="Retro Pal Pro" />

      <div class="pro-card">
        <div class="pro-headline">
          <h2 class="pro-title">Retro Pal Pro</h2>
          <p class="pro-tag">One purchase, that's it. For life.</p>
        </div>

        <div class="pro-pricing">
          <div class="pro-price">
            <span class="pro-amount">$4.99</span>
            <span class="pro-period">forever</span>
          </div>
          <span class="pro-or">or</span>
          <div class="pro-price secondary">
            <span class="pro-amount">$0.99</span>
            <span class="pro-period">/ month</span>
          </div>
        </div>

        <ul class="pro-perks">
          {proPerks.map((p) => (
            <li>
              <span class="pro-check" aria-hidden="true">✓</span>
              <span>{p}</span>
            </li>
          ))}
        </ul>

        <p class="pro-foot">
          The lifetime deal is our primary offering. The subscription exists for those who prefer it.
          Cancel anytime from the App Store. Switch from monthly to lifetime whenever you want.
        </p>
      </div>
    </div>
  </section>

  {/* ============================================================
       Privacy manifesto
       ============================================================ */}
  <section class="section privacy">
    <div class="page-shell privacy-inner">
      <SectionCounter index={5} total={6} label="Privacy" />

      <h2 class="display-h2 privacy-head">
        Made in France.<br />Zero tracking.<br /><span class="privacy-emph">For real.</span>
      </h2>

      <div class="privacy-body">
        <p>
          Retro Pal collects nothing. No analytics, no ads, no cookies, no unique identifiers.
          The app runs entirely offline. Your ROMs, your saves, your progress: everything stays on
          your iPhone.
        </p>
        <p>
          The only time any data leaves your phone is when <em>you</em> choose to share a screenshot.
          And even then, your Photos app handles it. Not us.
        </p>
        <p class="privacy-link">
          <a href="/en/privacy">Read the full privacy policy →</a>
        </p>
      </div>
    </div>
  </section>

  {/* ============================================================
       Closing — contact
       ============================================================ */}
  <section class="section closing">
    <div class="page-shell closing-inner">
      <SectionCounter index={6} total={6} label="Contact" />

      <h2 class="display-h2">Got a question or an idea?</h2>
      <p class="lead">
        Retro Pal is built by one person. Write me, I read everything.
      </p>

      <a class="btn closing-cta" href={`mailto:${SUPPORT_EMAIL}`}>
        <span>{SUPPORT_EMAIL}</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero — magazine cover */
  .hero {
    position: relative;
    padding-block: clamp(3rem, 7vw, 6rem) clamp(4rem, 9vw, 7rem);
    background:
      radial-gradient(
        ellipse 65% 55% at 75% 25%,
        rgba(118, 37, 196, 0.14),
        transparent 70%
      );
    overflow: hidden;
  }
  .hero-halftone {
    position: absolute;
    top: -10%;
    right: -8%;
    width: 55%;
    height: 80%;
    pointer-events: none;
    background-image: radial-gradient(var(--accent) 1.4px, transparent 1.6px);
    background-size: 14px 14px;
    opacity: 0.08;
    mask-image: radial-gradient(ellipse at top right, black 30%, transparent 75%);
    z-index: 0;
  }
  .hero-bottom-rule {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 4px;
    background: linear-gradient(
      to right,
      var(--accent) 0 16%,
      var(--ink) 16% 18%,
      var(--paper) 18% 22%,
      var(--ink) 22% 24%,
      var(--accent) 24% 50%,
      var(--ink) 50% 52%,
      var(--accent-dk) 52% 100%
    );
    image-rendering: pixelated;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .hero-cover-story {
    color: var(--accent-dk);
    font-weight: 500;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 13vw + 0.5rem, 11rem);
    line-height: 0.85;
    color: var(--ink);
    margin-bottom: 0.7rem;
    letter-spacing: -0.005em;
    display: flex;
    align-items: baseline;
    gap: 0.18em;
  }
  .hero-title-line { display: inline-block; }
  .hero-title-emph {
    color: var(--accent);
    transform: rotate(-2deg);
    text-shadow:
      4px 4px 0 var(--accent-dk),
      8px 8px 0 rgba(118, 37, 196, 0.2);
  }
  .hero-sub {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    color: var(--accent-dk);
    margin-bottom: 1.5rem;
  }
  .hero-lead {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--ink);
    line-height: 1.55;
    max-width: 54ch;
    margin-bottom: 2.25rem;
  }
  .hero-lead strong { font-style: normal; font-weight: 600; color: var(--ink); }
  .hero-lead em { font-style: italic; color: var(--accent-dk); font-weight: 600; }
  .hero-cta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .hero-secondary {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
  }
  .hero-secondary:hover { color: var(--ink); border-color: var(--accent-dk); }
  .hero-nameplate {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-faint);
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }
  .hero-nameplate .sep { color: var(--rule); }
  .hero-art { position: relative; display: grid; place-items: center; min-height: 360px; }
  .hero-art-grid {
    position: absolute;
    inset: -10% -8%;
    background-image:
      linear-gradient(to right, rgba(30, 26, 59, 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(30, 26, 59, 0.06) 1px, transparent 1px);
    background-size: 24px 24px;
    z-index: -1;
    mask-image: radial-gradient(circle at center, black 30%, transparent 80%);
  }
  .hero-sticker {
    position: absolute;
    top: -2%;
    right: -4%;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--paper);
    box-shadow:
      0 0 0 4px var(--paper),
      0 0 0 6px var(--accent-dk),
      6px 8px 0 rgba(81, 24, 138, 0.35);
    transform: rotate(14deg);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: center;
  }
  .hero-sticker-top { font-size: 0.55rem; opacity: 0.95; }
  .hero-sticker-big { font-family: var(--font-display); font-size: 1.85rem; letter-spacing: 0.02em; line-height: 1; }
  .hero-sticker-bot { font-size: 0.55rem; opacity: 0.9; }
  .hero-callout {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    line-height: 1.25;
    z-index: 2;
  }
  .cb-text {
    background: var(--paper);
    padding: 0.25rem 0.45rem;
    border: 1px solid var(--ink);
    box-shadow: 2px 2px 0 var(--accent);
  }
  .cb-arrow { font-family: var(--font-display); font-size: 1.6rem; color: var(--accent); line-height: 1; }
  .cb-1 { top: 12%; left: -2%; transform: rotate(-4deg); }
  .cb-2 { bottom: 18%; right: -2%; transform: rotate(3deg); }
  .cb-3 { bottom: -2%; left: 12%; transform: rotate(-2deg); }
  @media (max-width: 860px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero-art { order: -1; margin-bottom: 0.5rem; }
    .hero-callout { display: none; }
    .hero-sticker { width: 72px; height: 72px; top: -10px; right: 4px; }
    .hero-sticker-big { font-size: 1.4rem; }
  }

  /* Anti — editorial column with REJECTED stamps */
  .anti { position: relative; background: var(--paper-tint); }
  .anti-tape {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 8px;
    background-image: repeating-linear-gradient(
      to right,
      var(--paper) 0 8px,
      transparent 8px 12px
    );
  }
  .anti-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }
  .anti-head-wrap { position: relative; }
  .anti-head {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.2vw + 0.5rem, 3.5rem);
    line-height: 1.02;
    color: var(--ink);
  }
  .anti-sub {
    margin-top: 1rem;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--ink-soft);
    max-width: 32ch;
    line-height: 1.55;
  }
  .anti-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 1.85rem; }
  .anti-item {
    display: grid;
    gap: 0.6rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed var(--rule);
  }
  .anti-item:last-child { border-bottom: none; }
  .anti-row { display: inline-flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
  .anti-strike {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw + 0.5rem, 2.75rem);
    color: var(--ink);
    text-decoration: line-through;
    text-decoration-thickness: 4px;
    text-decoration-color: var(--alert-red);
    text-decoration-skip-ink: none;
    line-height: 1;
  }
  .anti-stamp {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--alert-red);
    padding: 0.2rem 0.85rem;
    border: 3px solid var(--alert-red);
    box-shadow: inset 0 0 0 2px var(--paper-tint), inset 0 0 0 4px var(--alert-red);
    transform: rotate(-7deg);
    opacity: 0.88;
    filter: drop-shadow(0 0 0.2px rgba(217, 65, 43, 0.5));
    position: relative;
  }
  .anti-stamp::before {
    content: "";
    position: absolute;
    inset: -2px;
    background: radial-gradient(
      circle at 30% 40%,
      transparent 0,
      transparent 70%,
      rgba(217, 65, 43, 0.18) 100%
    );
    pointer-events: none;
  }
  .anti-stamp-2 { transform: rotate(4deg); }
  .anti-stamp-3 { transform: rotate(-3deg); }
  .anti-note {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 50ch;
    padding-left: 0.1rem;
  }
  .anti-foot {
    grid-column: 1 / -1;
    margin-top: 1rem;
    padding-top: 2rem;
    border-top: 2px solid var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2vw + 0.5rem, 2rem);
    color: var(--ink);
    text-align: right;
    line-height: 1.2;
  }
  .anti-foot em { color: var(--accent-dk); font-style: italic; }
  .anti-sign {
    display: block;
    margin-top: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-style: italic;
    color: var(--ink-soft);
    font-weight: 400;
  }
  @media (max-width: 760px) {
    .anti-grid { grid-template-columns: 1fr; gap: 2rem; }
    .anti-foot { text-align: left; }
  }

  /* Systems */
  .systems-head {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.8vw + 0.5rem, 3rem);
    line-height: 1.05;
    color: var(--ink);
    margin-top: 1.5rem;
  }
  .systems-lead { margin-top: 1rem; max-width: 58ch; }
  .systems-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    align-items: end;
    justify-items: center;
  }
  @media (max-width: 720px) {
    .systems-grid { grid-template-columns: repeat(2, 1fr); gap: 2.5rem 1.5rem; }
  }

  /* Features */
  .feat-head {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.8vw + 0.5rem, 3rem);
    line-height: 1.05;
    color: var(--ink);
    margin-top: 1.5rem;
  }
  .feat-head-soft { color: var(--ink-soft); }
  .feat-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }
  .feat-card {
    position: relative;
    padding: 1.85rem 1.75rem 2rem;
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    transition: background-color 200ms ease;
  }
  .feat-card:hover { background: var(--paper-tint); }
  .feat-num {
    position: absolute;
    top: 1rem;
    right: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--ink-faint);
  }
  .feat-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }
  .feat-body { font-family: var(--font-body); font-size: 0.9375rem; line-height: 1.55; color: var(--ink-soft); }
  @media (max-width: 880px) { .feat-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .feat-grid { grid-template-columns: 1fr; } }

  /* Pro */
  .pro { background: var(--paper-tint); }
  .pro-card {
