---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionCounter from "../components/SectionCounter.astro";
import PixelDivider from "../components/PixelDivider.astro";
import Cartridge from "../components/Cartridge.astro";
import ConsoleIcon from "../components/ConsoleIcon.astro";
import AppStoreBadge from "../components/AppStoreBadge.astro";
import { SUPPORT_EMAIL } from "../i18n/ui";

const features = [
  {
    num: "01",
    title: "Émulation native",
    body:
      "GBA, Game Boy, Game Boy Color et Nintendo DS, propulsés par mGBA et melonDS. 60 images par seconde, accélération Metal, son stéréo.",
  },
  {
    num: "02",
    title: "Sauvegardes intelligentes",
    body:
      "Cinq emplacements de save state (deux gratuits), aperçus en image, sauvegarde automatique en arrière-plan. Tu reprends exactement où tu t'es arrêté.",
  },
  {
    num: "03",
    title: "Rembobinage 30 secondes",
    body:
      "Une erreur en plein combat de boss ? Tu rembobines jusqu'à trente secondes (Pro). Cinq secondes en gratuit. Le moyen le plus rapide d'éviter le game over.",
  },
  {
    num: "04",
    title: "Vitesse 0.25× à 4×",
    body:
      "Ralenti pour les passages difficiles, turbo pour les grinds. Tu choisis. 1× et 1.5× en gratuit, le reste avec Pro.",
  },
  {
    num: "05",
    title: "Codes de triche",
    body:
      "GameShark, CodeBreaker, Action Replay, Action Replay DS. Codes nommés, activables un par un, sauvegarde automatique avant activation.",
  },
  {
    num: "06",
    title: "Contrôles personnalisables",
    body:
      "Déplace le D-pad, les boutons, ajuste l'opacité et la taille. Jusqu'à trois préréglages par système. Tes mains, ta disposition.",
  },
  {
    num: "07",
    title: "Captures partageables",
    body:
      "Une carte de partage générée automatiquement avec le titre du jeu, ton temps de jeu cumulé et ton tier de joueur. Belle, instantanée, prête pour Instagram.",
  },
  {
    num: "08",
    title: "Hors-ligne intégral",
    body:
      "Aucune connexion requise pour jouer. Tes ROMs, tes sauvegardes, tes parties restent sur ton iPhone. Pour toujours.",
  },
  {
    num: "09",
    title: "Dix langues européennes",
    body:
      "Français, anglais, allemand, espagnol, italien, néerlandais, polonais, portugais, suédois, roumain. Localisée par un humain, pas par une machine.",
  },
];

const proPerks = [
  "Toutes les vitesses : 0.25×, 0.5×, 2×, 3×, 4×",
  "Cinq emplacements de sauvegarde (au lieu de deux)",
  "Trente secondes de rembobinage (GBA / GB / GBC)",
  "Codes de triche illimités",
  "Mises en page de contrôles personnalisées, jusqu'à trois préréglages",
];
---

<BaseLayout title="Retro Pal" isHome={true}>
  {/* ============================================================
       Hero
       ============================================================ */}
  <section class="hero scanlines" id="hero">
    <div class="page-shell hero-inner">
      <div class="hero-content">
        <div class="hero-eyebrow rise rise-d1">
          <span class="tape">Bêta privée · 2026</span>
          <span class="kicker">Émulateur iOS</span>
        </div>

        <h1 class="hero-title rise rise-d2">Retro Pal</h1>

        <p class="hero-sub rise rise-d3">L'émulateur rétro que ton iPhone mérite.</p>

        <p class="hero-lead lead rise rise-d4">
          Joue à tes jeux <strong>GBA</strong>, <strong>Game Boy</strong>,
          <strong>Game Boy Color</strong> et <strong>Nintendo DS</strong> sur iPhone.
          Sans pub, sans collecte de données, sans abonnement obligatoire.
          <em>Pour toujours.</em>
        </p>

        <div class="hero-cta rise rise-d5">
          <AppStoreBadge locale="fr" />
          <a href="#features" class="hero-secondary">Voir les fonctionnalités →</a>
        </div>

        <p class="hero-nameplate rise rise-d5">
          <span>Fait en France</span>
          <span class="sep">·</span>
          <span>Zéro tracking</span>
          <span class="sep">·</span>
          <span>Open source</span>
        </p>
      </div>

      <div class="hero-art" aria-hidden="true">
        <Cartridge tilt={-4} />
        <div class="hero-art-grid"></div>
      </div>
    </div>
  </section>

  {/* ============================================================
       Anti-feature manifesto
       ============================================================ */}
  <section class="section anti" id="anti">
    <div class="page-shell">
      <SectionCounter index={1} total={6} label="Notre seule promesse" />

      <div class="anti-grid">
        <h2 class="display-h2 anti-head">
          Tu achètes une fois.<br />Tu joues pour toujours.
        </h2>

        <ul class="anti-list" aria-label="Ce qu'il n'y a pas dans Retro Pal">
          <li class="anti-item">
            <span class="anti-strike">Pub</span>
            <span class="anti-note">Jamais. Pas même une bannière "non intrusive".</span>
          </li>
          <li class="anti-item">
            <span class="anti-strike">Collecte de données</span>
            <span class="anti-note">Pas d'analytics. Pas de cookies. Pas d'identifiant.</span>
          </li>
          <li class="anti-item">
            <span class="anti-strike">Abonnement obligatoire</span>
            <span class="anti-note">4,99 € une fois, à vie. L'abonnement existe, mais reste optionnel.</span>
          </li>
        </ul>

        <p class="anti-foot">
          On vend une app. On ne vend pas <em>toi</em>.
        </p>
      </div>
    </div>
  </section>

  {/* ============================================================
       Systems supported
       ============================================================ */}
  <section class="section systems">
    <div class="page-shell">
      <SectionCounter index={2} total={6} label="Quatre consoles" />

      <h2 class="display-h2 systems-head">
        Tout le catalogue rétro Nintendo portable.
      </h2>
      <p class="lead systems-lead">
        Un seul émulateur, quatre générations. De la brique grise de 1989 au double écran de 2004.
      </p>

      <div class="systems-grid">
        <ConsoleIcon system="gb" />
        <ConsoleIcon system="gbc" />
        <ConsoleIcon system="gba" />
        <ConsoleIcon system="nds" />
      </div>

      <PixelDivider variant="blocks" />
    </div>
  </section>

  {/* ============================================================
       Features grid (magazine-style)
       ============================================================ */}
  <section class="section features" id="features">
    <div class="page-shell">
      <SectionCounter index={3} total={6} label="Fonctionnalités" />

      <h2 class="display-h2 feat-head">
        Tout ce qu'un émulateur sérieux devrait faire.<br />
        <span class="feat-head-soft">Et rien qu'il ne devrait pas.</span>
      </h2>

      <div class="feat-grid">
        {features.map((f) => (
          <article class="feat-card">
            <span class="feat-num">{f.num}</span>
            <h3 class="feat-title">{f.title}</h3>
            <p class="feat-body">{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ============================================================
       Pro pricing block
       ============================================================ */}
  <section class="section pro" id="pro">
    <div class="page-shell pro-shell">
      <SectionCounter index={4} total={6} label="Retro Pal Pro" />

      <div class="pro-card">
        <div class="pro-headline">
          <h2 class="pro-title">Retro Pal Pro</h2>
          <p class="pro-tag">Un seul achat, c'est tout. Pour la vie.</p>
        </div>

        <div class="pro-pricing">
          <div class="pro-price">
            <span class="pro-amount">4,99 €</span>
            <span class="pro-period">à vie</span>
          </div>
          <span class="pro-or">ou</span>
          <div class="pro-price secondary">
            <span class="pro-amount">0,99 €</span>
            <span class="pro-period">/ mois</span>
          </div>
        </div>

        <ul class="pro-perks">
          {proPerks.map((p) => (
            <li>
              <span class="pro-check" aria-hidden="true">✓</span>
              <span>{p}</span>
            </li>
          ))}
        </ul>

        <p class="pro-foot">
          Le tarif à vie est notre principale offre. L'abonnement existe pour ceux qui préfèrent.
          Tu peux annuler à tout moment depuis l'App Store. Tu peux passer du mensuel au lifetime quand tu veux.
        </p>
      </div>
    </div>
  </section>

  {/* ============================================================
       Privacy manifesto
       ============================================================ */}
  <section class="section privacy">
    <div class="page-shell privacy-inner">
      <SectionCounter index={5} total={6} label="Vie privée" />

      <h2 class="display-h2 privacy-head">
        Fait en France.<br />Zéro tracking.<br /><span class="privacy-emph">Vraiment.</span>
      </h2>

      <div class="privacy-body">
        <p>
          Retro Pal ne collecte rien. Pas d'analytics, pas de pubs, pas de cookies, pas d'identifiant unique.
          L'app fonctionne entièrement hors-ligne. Tes ROMs, tes sauvegardes, ta progression :
          tout reste sur ton iPhone.
        </p>
        <p>
          Le seul moment où une donnée quitte ton téléphone, c'est quand <em>toi</em> tu décides de partager une capture d'écran.
          Et même là, c'est ton appli Photos qui s'en occupe, pas nous.
        </p>
        <p class="privacy-link">
          <a href="/confidentialite">Lire la politique de confidentialité complète →</a>
        </p>
      </div>
    </div>
  </section>

  {/* ============================================================
       Closing — contact
       ============================================================ */}
  <section class="section closing">
    <div class="page-shell closing-inner">
      <SectionCounter index={6} total={6} label="Contact" />

      <h2 class="display-h2">Une question, une suggestion ?</h2>
      <p class="lead">
        Retro Pal est développé par une seule personne. Écris-moi, je réponds.
      </p>

      <a class="btn closing-cta" href={`mailto:${SUPPORT_EMAIL}`}>
        <span>{SUPPORT_EMAIL}</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     Hero
     ============================================================ */
  .hero {
    position: relative;
    padding-block: clamp(3rem, 7vw, 6rem) clamp(4rem, 9vw, 7rem);
    background:
      radial-gradient(
        ellipse 60% 50% at 80% 20%,
        rgba(118, 37, 196, 0.12),
        transparent 70%
      );
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.3fr 0.9fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 11vw + 0.5rem, 9rem);
    line-height: 0.9;
    color: var(--ink);
    margin-bottom: 0.8rem;
    letter-spacing: 0.005em;
  }

  .hero-sub {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    color: var(--accent-dk);
    margin-bottom: 1.5rem;
    letter-spacing: 0.01em;
  }

  .hero-lead {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--ink);
    line-height: 1.55;
    max-width: 54ch;
    margin-bottom: 2.25rem;
  }

  .hero-lead strong {
    font-style: normal;
    font-weight: 600;
    color: var(--ink);
  }

  .hero-lead em {
    font-style: italic;
    color: var(--accent-dk);
    font-weight: 600;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .hero-secondary {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    transition: color 120ms ease, border-color 120ms ease;
  }

  .hero-secondary:hover {
    color: var(--ink);
    border-color: var(--accent-dk);
  }

  .hero-nameplate {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-faint);
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }

  .hero-nameplate .sep {
    color: var(--rule);
  }

  .hero-art {
    position: relative;
    display: grid;
    place-items: center;
  }

  .hero-art-grid {
    position: absolute;
    inset: -10% -8%;
    background-image:
      linear-gradient(to right, rgba(26, 24, 20, 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(26, 24, 20, 0.06) 1px, transparent 1px);
    background-size: 24px 24px;
    z-index: -1;
    mask-image: radial-gradient(circle at center, black 30%, transparent 80%);
  }

  @media (max-width: 860px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .hero-art {
      order: -1;
      margin-bottom: 0.5rem;
    }
  }

  /* ============================================================
     Anti
     ============================================================ */
  .anti {
    background: var(--paper-tint);
  }

  .anti-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1.1fr 1.4fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .anti-head {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.8vw + 0.5rem, 3.25rem);
    line-height: 1.05;
    color: var(--ink);
  }

  .anti-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
  }

  .anti-item {
    display: grid;
    grid-template-columns: minmax(min-content, 12rem) 1fr;
    gap: 1.5rem;
    align-items: baseline;
    padding-bottom: 1.25rem;
    border-bottom: 1px dashed var(--rule);
  }

  .anti-item:last-child {
    border-bottom: none;
  }

  .anti-strike {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--alert-red);
    text-decoration: line-through;
    text-decoration-thickness: 3px;
    text-decoration-color: var(--alert-red);
    text-decoration-skip-ink: none;
  }

  .anti-note {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .anti-foot {
    grid-column: 1 / -1;
    margin-top: 1.5rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--ink);
    text-align: right;
  }

  @media (max-width: 760px) {
    .anti-grid {
      grid-template-columns: 1fr;
    }
    .anti-foot {
      text-align: left;
    }
  }

  /* ============================================================
     Systems
     ============================================================ */
  .systems-head {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.8vw + 0.5rem, 3rem);
    line-height: 1.05;
    color: var(--ink);
    margin-top: 1.5rem;
  }

  .systems-lead {
    margin-top: 1rem;
    max-width: 58ch;
  }

  .systems-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    align-items: end;
    justify-items: center;
  }

  @media (max-width: 720px) {
    .systems-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem 1.5rem;
    }
  }

  /* ============================================================
     Features
     ============================================================ */
  .feat-head {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.8vw + 0.5rem, 3rem);
    line-height: 1.05;
    color: var(--ink);
    margin-top: 1.5rem;
  }

  .feat-head-soft {
    color: var(--ink-soft);
  }

  .feat-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }

  .feat-card {
    position: relative;
    padding: 1.85rem 1.75rem 2rem;
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    transition: background-color 200ms ease;
  }

  .feat-card:hover {
    background: var(--paper-tint);
  }

  .feat-num {
    position: absolute;
    top: 1rem;
    right: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--ink-faint);
  }

  .feat-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  .feat-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  @media (max-width: 880px) {
    .feat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .feat-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ============================================================
     Pro
     ============================================================ */
  .pro {
    background: var(--paper-tint);
  }

  .pro-card {
    margin-top: 2rem;
    background: var(--paper);
    border: 2px solid var(--ink);
    padding: clamp(1.75rem, 4vw, 3rem);
    position: relative;
    box-shadow: 8px 8px 0 var(--gold-pro-dk);
  }

  .pro-card::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(
      var(--gold-pro) 1px,
      transparent 1.2px
    );
    background-size: 24px 24px;
    opacity: 0.08;
  }

  .pro-headline {
    position: relative;
  }

  .pro-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw + 0.5rem, 3.5rem);
    color: var(--gold-pro-dk);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .pro-tag {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.125rem;
    color: var(--ink-soft);
  }

  .pro-pricing {
    margin-top: 2rem;
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    flex-wrap: wrap;
    position: relative;
  }

  .pro-price {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .pro-amount {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw + 0.5rem, 4rem);
    color: var(--ink);
    line-height: 1;
  }

  .pro-period {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .pro-price.secondary .pro-amount {
    font-size: 2rem;
    color: var(--ink-soft);
  }

  .pro-or {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .pro-perks {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
    position: relative;
  }

  .pro-perks li {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink);
    align-items: baseline;
  }

  .pro-check {
    font-family: var(--font-display);
    color: var(--gold-pro-dk);
    font-size: 1.25rem;
    line-height: 1;
  }

  .pro-foot {
    margin-top: 2rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--ink-soft);
    line-height: 1.6;
    max-width: 60ch;
    position: relative;
  }

  /* ============================================================
     Privacy
     ============================================================ */
  .privacy-inner {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .privacy-head {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw + 0.5rem, 4rem);
    line-height: 1;
    color: var(--ink);
    margin-top: 1.5rem;
  }

  .privacy-emph {
    color: var(--accent-dk);
    position: relative;
    display: inline-block;
  }

  .privacy-emph::after {
    content: "";
    position: absolute;
    left: -4px;
    right: -4px;
    bottom: -2px;
    height: 5px;
    background: var(--accent);
    z-index: -1;
    transform: skewY(-1.5deg);
  }

  .privacy-body {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--ink);
    max-width: 56ch;
    margin-top: 2.25rem;
  }

  .privacy-body p + p {
    margin-top: 1.1em;
  }

  .privacy-body em {
    color: var(--accent-dk);
    font-style: italic;
  }

  .privacy-link {
    margin-top: 1.5rem !important;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .privacy-link a {
    color: var(--accent-dk);
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }

  @media (max-width: 760px) {
    .privacy-inner {
      grid-template-columns: 1fr;
    }
    .privacy-body {
      margin-top: 0;
    }
  }

  /* ============================================================
     Closing
     ============================================================ */
  .closing {
    text-align: center;
    background: var(--paper);
  }

  .closing-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .closing .display-h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    color: var(--ink);
    margin-top: 1rem;
  }

  .closing .lead {
    max-width: 44ch;
  }

  .closing-cta {
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    text-transform: none;
