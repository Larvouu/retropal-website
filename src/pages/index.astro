---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionCounter from "../components/SectionCounter.astro";
import PixelDivider from "../components/PixelDivider.astro";
import Cartridge from "../components/Cartridge.astro";
import ConsoleIcon from "../components/ConsoleIcon.astro";
import AppStoreBadge from "../components/AppStoreBadge.astro";
import { SUPPORT_EMAIL } from "../i18n/ui";

const features = [
  {
    num: "01",
    title: "Émulation native",
    body:
      "GBA, Game Boy, Game Boy Color et Nintendo DS, propulsés par mGBA et melonDS. 60 images par seconde, accélération Metal, son stéréo.",
  },
  {
    num: "02",
    title: "Sauvegardes intelligentes",
    body:
      "Cinq emplacements de save state (deux gratuits), aperçus en image, sauvegarde automatique en arrière-plan. Tu reprends exactement où tu t'es arrêté.",
  },
  {
    num: "03",
    title: "Rembobinage 30 secondes",
    body:
      "Une erreur en plein combat de boss ? Tu rembobines jusqu'à trente secondes (Pro). Cinq secondes en gratuit. Le moyen le plus rapide d'éviter le game over.",
  },
  {
    num: "04",
    title: "Vitesse 0.25× à 4×",
    body:
      "Ralenti pour les passages difficiles, turbo pour les grinds. Tu choisis. 1× et 1.5× en gratuit, le reste avec Pro.",
  },
  {
    num: "05",
    title: "Codes de triche",
    body:
      "GameShark, CodeBreaker, Action Replay, Action Replay DS. Codes nommés, activables un par un, sauvegarde automatique avant activation.",
  },
  {
    num: "06",
    title: "Contrôles personnalisables",
    body:
      "Déplace le D-pad, les boutons, ajuste l'opacité et la taille. Jusqu'à trois préréglages par système. Tes mains, ta disposition.",
  },
  {
    num: "07",
    title: "Captures partageables",
    body:
      "Une carte de partage générée automatiquement avec le titre du jeu, ton temps de jeu cumulé et ton tier de joueur. Belle, instantanée, prête pour Instagram.",
  },
  {
    num: "08",
    title: "Hors-ligne intégral",
    body:
      "Aucune connexion requise pour jouer. Tes ROMs, tes sauvegardes, tes parties restent sur ton iPhone. Pour toujours.",
  },
  {
    num: "09",
    title: "Dix langues européennes",
    body:
      "Français, anglais, allemand, espagnol, italien, néerlandais, polonais, portugais, suédois, roumain. Localisée par un humain, pas par une machine.",
  },
];

const proPerks = [
  "Toutes les vitesses : 0.25×, 0.5×, 2×, 3×, 4×",
  "Cinq emplacements de sauvegarde (au lieu de deux)",
  "Trente secondes de rembobinage (GBA / GB / GBC)",
  "Codes de triche illimités",
  "Mises en page de contrôles personnalisées, jusqu'à trois préréglages",
];
---

<BaseLayout title="Retro Pal" isHome={true}>
  {/* ============================================================
       Hero, magazine cover spread
       ============================================================ */}
  <section class="hero scanlines" id="hero">
    <div class="hero-halftone" aria-hidden="true"></div>

    <div class="page-shell hero-inner">
      <div class="hero-content">
        <div class="hero-eyebrow rise rise-d1">
          <span class="kicker hero-cover-story">★ Cover Story</span>
          <span class="tape">Bêta privée · 2026</span>
        </div>

        <h1 class="hero-title rise rise-d2">
          <span class="hero-title-line">Retro</span>
          <span class="hero-title-line hero-title-emph">Pal</span>
        </h1>

        <p class="hero-sub rise rise-d3">La console de ton enfance. Maintenant dans ta poche.</p>

        <p class="hero-lead lead rise rise-d4">
          Joue à tes jeux <strong>GBA</strong>, <strong>Game Boy</strong>,
          <strong>Game Boy Color</strong> et <strong>Nintendo DS</strong> sur iPhone.
          Sans pub, sans collecte de données, sans abonnement obligatoire.
          <em>Pour toujours.</em>
        </p>

        <div class="hero-cta rise rise-d5">
          <AppStoreBadge locale="fr" />
          <a href="#features" class="hero-secondary">Voir les fonctionnalités →</a>
        </div>

        <p class="hero-nameplate rise rise-d5">
          <span>Fait en France</span>
          <span class="sep">·</span>
          <span>Zéro tracking</span>
          <span class="sep">·</span>
          <span>Open source</span>
        </p>
      </div>

      <div class="hero-art" aria-hidden="true">
        <Cartridge tilt={-4} />

        <div class="hero-art-grid"></div>

        {/* Magazine callouts pointing at the cartridge */}
        <span class="hero-callout cb-1">
          <span class="cb-arrow">→</span>
          <span class="cb-text">Quatre consoles<br />dans une seule app</span>
        </span>
        <span class="hero-callout cb-2">
          <span class="cb-text">Rembobinage<br />30 secondes</span>
          <span class="cb-arrow">←</span>
        </span>
        <span class="hero-callout cb-3">
          <span class="cb-arrow">↗</span>
          <span class="cb-text">Zéro pub<br />zéro tracking</span>
        </span>
      </div>
    </div>

    <div class="hero-bottom-rule" aria-hidden="true"></div>
  </section>

  {/* ============================================================
       Anti-feature manifesto, editorial column with REJETÉ stamps
       ============================================================ */}
  <section class="section anti" id="anti">
    <div class="anti-tape" aria-hidden="true"></div>
    <div class="page-shell">
      <SectionCounter index={1} total={6} label="De la rédaction" />

      <div class="anti-grid">
        <div class="anti-head-wrap">
          <h2 class="display-h2 anti-head">
            Tu achètes une fois.<br />Tu joues pour toujours.
          </h2>
          <p class="anti-sub">
            Trois choses que tu ne trouveras jamais dans Retro Pal.
            C'est l'éditorial du mois.
          </p>
        </div>

        <ul class="anti-list" aria-label="Ce qu'il n'y a pas dans Retro Pal">
          <li class="anti-item">
            <span class="anti-row">
              <span class="anti-strike">Pub</span>
              <span class="anti-stamp" aria-hidden="true">Rejeté</span>
            </span>
            <span class="anti-note">Jamais. Pas même une bannière « non intrusive ».</span>
          </li>
          <li class="anti-item">
            <span class="anti-row">
              <span class="anti-strike">Collecte de données</span>
              <span class="anti-stamp anti-stamp-2" aria-hidden="true">Rejeté</span>
            </span>
            <span class="anti-note">Pas d'analytics. Pas de cookies. Pas d'identifiant.</span>
          </li>
          <li class="anti-item">
            <span class="anti-row">
              <span class="anti-strike">Abonnement obligatoire</span>
              <span class="anti-stamp anti-stamp-3" aria-hidden="true">Rejeté</span>
            </span>
            <span class="anti-note">4,99 € une fois, à vie. L'abonnement existe, mais reste optionnel.</span>
          </li>
        </ul>

        <p class="anti-foot">
          On vend une app. On ne vend pas <em>toi</em>.
        </p>
      </div>
    </div>
  </section>

  {/* ============================================================
       Systems supported
       ============================================================ */}
  <section class="section systems">
    <div class="page-shell">
      <SectionCounter index={2} total={6} label="Quatre consoles" />

      <h2 class="display-h2 systems-head">
        Tout le catalogue rétro Nintendo portable.
      </h2>
      <p class="lead systems-lead">
        Un seul émulateur, quatre générations. De la brique grise de 1989 au double écran de 2004.
      </p>

      <div class="systems-grid">
        <ConsoleIcon system="gb" />
        <ConsoleIcon system="gbc" />
        <ConsoleIcon system="gba" />
        <ConsoleIcon system="nds" />
      </div>

      <PixelDivider variant="blocks" />
    </div>
  </section>

  {/* ============================================================
       Features grid (magazine-style)
       ============================================================ */}
  <section class="section features" id="features">
    <div class="page-shell">
      <SectionCounter index={3} total={6} label="Sommaire" />

      <h2 class="display-h2 feat-head">
        Tout ce qu'un émulateur sérieux devrait faire.<br />
        <span class="feat-head-soft">Et rien qu'il ne devrait pas.</span>
      </h2>

      <div class="feat-grid">
        {features.map((f, i) => (
          <article class:list={["feat-card", { "feat-featured": i === 0 }]}>
            {i === 0 && <span class="feat-badge">★ À la une</span>}
            <span class="feat-num">{f.num}</span>
            <h3 class="feat-title">{f.title}</h3>
            <p class="feat-body">{f.body}</p>
          </article>
        ))}
      </div>

      <figure class="feat-pullquote">
        <blockquote>
          « Le meilleur émulateur, c'est celui qu'on ne remarque pas. »
        </blockquote>
      </figure>
    </div>
  </section>

  {/* ============================================================
       Pro pricing block, magazine subscription pitch
       ============================================================ */}
  <section class="section pro" id="pro">
    <div class="page-shell pro-shell">
      <SectionCounter index={4} total={6} label="Abonne-toi · sauf que non" />

      <div class="pro-card">
        {/* SPECIAL OFFER! tape sticker in the top-right corner */}
        <span class="pro-sticker" aria-hidden="true">
          <span class="pro-sticker-line">Offre</span>
          <span class="pro-sticker-line pro-sticker-big">Spéciale!</span>
          <span class="pro-sticker-line">★ ★ ★</span>
        </span>

        <div class="pro-headline">
          <span class="pro-eyebrow">★ Retro Pal Pro · Le coupon</span>
          <h2 class="pro-title">4,99 €. Une fois. Fini.</h2>
          <p class="pro-tag">
            On t'a tellement parlé d'abonnement que tu ne te souviens même plus
            de ce que signifie « acheter une app ». Ça : c'est ça.
          </p>
        </div>

        <div class="pro-pricing">
          <div class="pro-price-burst" aria-hidden="true">
            {/* CSS-only sunburst behind the price */}
          </div>
          <div class="pro-price-main">
            <div class="pro-price">
              <span class="pro-amount">4,99 €</span>
              <span class="pro-period">à vie</span>
            </div>
            <span class="pro-divider"></span>
            <div class="pro-price secondary">
              <span class="pro-amount-small">ou 0,99 €</span>
              <span class="pro-period">/ mois</span>
            </div>
          </div>
        </div>

        <div class="pro-perks-wrap">
          <p class="pro-perks-head">Ce que tu débloques :</p>
          <ul class="pro-perks">
            {proPerks.map((p) => (
              <li>
                <span class="pro-check" aria-hidden="true">✓</span>
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </div>

        <p class="pro-foot">
          <strong>Le tarif à vie est notre offre principale.</strong>
          L'abonnement existe pour ceux qui préfèrent payer petit-à-petit.
          Tu peux annuler à tout moment depuis l'App Store. Tu peux passer du mensuel au lifetime quand tu veux.
        </p>
      </div>
    </div>
  </section>

  {/* ============================================================
       Privacy manifesto
       ============================================================ */}
  <section class="section privacy">
    <div class="page-shell privacy-inner">
      <SectionCounter index={5} total={6} label="Vie privée" />

      <h2 class="display-h2 privacy-head">
        Fait en France.<br />Zéro tracking.<br /><span class="privacy-emph">Vraiment.</span>
      </h2>

      <div class="privacy-body">
        <p>
          Retro Pal ne collecte rien. Pas d'analytics, pas de pubs, pas de cookies, pas d'identifiant unique.
          L'app fonctionne entièrement hors-ligne. Tes ROMs, tes sauvegardes, ta progression :
          tout reste sur ton iPhone.
        </p>
        <p>
          Le seul moment où une donnée quitte ton téléphone, c'est quand <em>toi</em> tu décides de partager une capture d'écran.
          Et même là, c'est ton appli Photos qui s'en occupe, pas nous.
        </p>
        <p class="privacy-link">
          <a href="/confidentialite">Lire la politique de confidentialité complète →</a>
        </p>
      </div>
    </div>
  </section>

  {/* ============================================================
       Closing, magazine mailbag
       ============================================================ */}
  <section class="section closing">
    <div class="page-shell closing-inner">
      <SectionCounter index={6} total={6} label="Le courrier des lecteurs" />

      <div class="closing-postcard">
        <span class="closing-stamp" aria-hidden="true">
          <span class="closing-stamp-inner">
            <span class="closing-stamp-top">★ Retro</span>
            <span class="closing-stamp-mid">Pal</span>
            <span class="closing-stamp-bot">N° 01</span>
          </span>
        </span>
        <div class="closing-postcard-body">
          <span class="closing-eyebrow">À l'attention de</span>
          <h2 class="closing-title">Une seule personne.<br />Une vraie adresse.</h2>
          <p class="closing-text">
            Retro Pal est développé par moi tout seul. Une question, une idée, un bug,
            un compliment, une plainte ? Écris. Je lis tout, je réponds.
          </p>
        </div>
      </div>

      <a class="closing-mail-cta" href={`mailto:${SUPPORT_EMAIL}`}>
        <span class="closing-mail-arrow">→</span>
        <span class="closing-mail-addr">{SUPPORT_EMAIL}</span>
      </a>

      <p class="closing-postmark">
        <span class="closing-postmark-circle">★</span>
        Posté de France &middot; Maintenant
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     Hero, magazine cover
     ============================================================ */
  .hero {
    position: relative;
    padding-block: clamp(3rem, 7vw, 6rem) clamp(4rem, 9vw, 7rem);
    background:
      radial-gradient(
        ellipse 65% 55% at 75% 25%,
        rgba(118, 37, 196, 0.14),
        transparent 70%
      );
    overflow: hidden;
  }

  /* Halftone dot pattern bleeding from the corner */
  .hero-halftone {
    position: absolute;
    top: -10%;
    right: -8%;
    width: 55%;
    height: 80%;
    pointer-events: none;
    background-image: radial-gradient(
      var(--accent) 1.4px,
      transparent 1.6px
    );
    background-size: 14px 14px;
    opacity: 0.08;
    mask-image: radial-gradient(ellipse at top right, black 30%, transparent 75%);
    z-index: 0;
  }

  .hero-bottom-rule {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 4px;
    background: linear-gradient(
      to right,
      var(--accent) 0 16%,
      var(--ink) 16% 18%,
      var(--paper) 18% 22%,
      var(--ink) 22% 24%,
      var(--accent) 24% 50%,
      var(--ink) 50% 52%,
      var(--accent-dk) 52% 100%
    );
    image-rendering: pixelated;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .hero-cover-story {
    color: var(--accent-dk);
    font-weight: 500;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 13vw + 0.5rem, 11rem);
    line-height: 0.85;
    color: var(--ink);
    margin-bottom: 0.7rem;
    letter-spacing: -0.005em;
    display: flex;
    align-items: baseline;
    gap: 0.18em;
  }

  .hero-title-line {
    display: inline-block;
  }

  .hero-title-emph {
    color: var(--accent);
    transform: rotate(-2deg);
    text-shadow:
      4px 4px 0 var(--accent-dk),
      8px 8px 0 rgba(118, 37, 196, 0.2);
  }

  .hero-sub {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    color: var(--accent-dk);
    margin-bottom: 1.5rem;
    letter-spacing: 0.01em;
  }

  .hero-lead {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--ink);
    line-height: 1.55;
    max-width: 54ch;
    margin-bottom: 2.25rem;
  }

  .hero-lead strong {
    font-style: normal;
    font-weight: 600;
    color: var(--ink);
  }

  .hero-lead em {
    font-style: italic;
    color: var(--accent-dk);
    font-weight: 600;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .hero-secondary {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    transition: color 120ms ease, border-color 120ms ease;
  }

  .hero-secondary:hover {
    color: var(--ink);
    border-color: var(--accent-dk);
  }

  .hero-nameplate {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-faint);
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }

  .hero-nameplate .sep {
    color: var(--rule);
  }

  .hero-art {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 360px;
  }

  .hero-art-grid {
    position: absolute;
    inset: -10% -8%;
    background-image:
      linear-gradient(to right, rgba(30, 26, 59, 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(30, 26, 59, 0.06) 1px, transparent 1px);
    background-size: 24px 24px;
    z-index: -1;
    mask-image: radial-gradient(circle at center, black 30%, transparent 80%);
  }

  /* Magazine callouts, text+arrow pointing at the cartridge */
  .hero-callout {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    line-height: 1.25;
    z-index: 2;
  }

  .cb-text {
    background: var(--paper);
    padding: 0.25rem 0.45rem;
    border: 1px solid var(--ink);
    box-shadow: 2px 2px 0 var(--accent);
  }

  .cb-arrow {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--accent);
    line-height: 1;
  }

  .cb-1 {
    top: 12%;
    left: -2%;
    transform: rotate(-4deg);
  }

  .cb-2 {
    bottom: 18%;
    right: -2%;
    transform: rotate(3deg);
  }

  .cb-3 {
    bottom: -2%;
    left: 12%;
    transform: rotate(-2deg);
  }

  @media (max-width: 860px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .hero-art {
      order: -1;
      margin-bottom: 0.5rem;
    }
    .hero-callout {
      display: none;
    }
  }

  /* ============================================================
     Anti, editorial column with REJETÉ stamps
     ============================================================ */
  .anti {
    position: relative;
    background: var(--paper-tint);
  }

  /* Perforated top edge to look like a tear */
  .anti-tape {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 8px;
    background-image: repeating-linear-gradient(
      to right,
      var(--paper) 0 8px,
      transparent 8px 12px
    );
  }

  .anti-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .anti-head-wrap {
    position: relative;
  }

  .anti-head {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.2vw + 0.5rem, 3.5rem);
    line-height: 1.02;
    color: var(--ink);
  }

  .anti-sub {
    margin-top: 1rem;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--ink-soft);
    max-width: 32ch;
    line-height: 1.55;
  }

  .anti-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.85rem;
  }

  .anti-item {
    display: grid;
    gap: 0.6rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed var(--rule);
  }

  .anti-item:last-child {
    border-bottom: none;
  }

  .anti-row {
    display: inline-flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .anti-strike {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw + 0.5rem, 2.75rem);
    color: var(--ink);
    text-decoration: line-through;
    text-decoration-thickness: 4px;
    text-decoration-color: var(--alert-red);
    text-decoration-skip-ink: none;
    line-height: 1;
  }

  /* Rubber stamp: red ink "REJETÉ" with double border and rotation */
  .anti-stamp {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--alert-red);
    padding: 0.2rem 0.85rem;
    border: 3px solid var(--alert-red);
    box-shadow: inset 0 0 0 2px var(--paper-tint), inset 0 0 0 4px var(--alert-red);
    transform: rotate(-7deg);
    opacity: 0.88;
    /* Faint ink-bleed effect */
    filter: drop-shadow(0 0 0.2px rgba(217, 65, 43, 0.5));
    position: relative;
  }

  .anti-stamp::before {
    content: "";
    position: absolute;
    inset: -2px;
    background: radial-gradient(
      circle at 30% 40%,
      transparent 0,
      transparent 70%,
      rgba(217, 65, 43, 0.18) 100%
    );
    pointer-events: none;
  }

  .anti-stamp-2 {
    transform: rotate(4deg);
  }

  .anti-stamp-3 {
    transform: rotate(-3deg);
  }

  .anti-note {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 50ch;
    padding-left: 0.1rem;
  }

  .anti-foot {
    grid-column: 1 / -1;
    margin-top: 1rem;
    padding-top: 2rem;
    border-top: 2px solid var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2vw + 0.5rem, 2rem);
    color: var(--ink);
    text-align: right;
    line-height: 1.2;
  }

  .anti-foot em {
    color: var(--accent-dk);
    font-style: italic;
  }

