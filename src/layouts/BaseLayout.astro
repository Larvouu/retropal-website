---
import "../styles/global.css";
import MagazineMasthead from "../components/MagazineMasthead.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import type { Locale } from "../i18n/ui";
import { getUi, localeFromPath } from "../i18n/ui";

export interface Props {
  title: string;
  description?: string;
  /** Override the locale detected from the URL. Usually leave empty. */
  locale?: Locale;
  /** Path relative to site root, e.g. "/og-image.png" */
  ogImage?: string;
  /** True on the home page only — avoids redundant ":: Retro Pal" suffix */
  isHome?: boolean;
}

const {
  title,
  description,
  locale = localeFromPath(Astro.url.pathname),
  ogImage = "/og-image.png",
  isHome = false,
} = Astro.props;

const ui = getUi(locale);
const fullTitle = isHome ? `${ui.meta.siteName} — ${ui.meta.tagline}` : `${title} · ${ui.meta.siteName}`;
const metaDescription = description ?? ui.meta.description;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang={locale} class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#DFF9FB" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === "fr" ? "fr_FR" : "en_US"} />
    <meta property="og:site_name" content={ui.meta.siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Alternates -->
    <link
      rel="alternate"
      hreflang="fr"
      href={new URL(Astro.url.pathname.replace(/^\/en/, "") || "/", Astro.site).toString()}
    />
    <link
      rel="alternate"
      hreflang="en"
      href={new URL(
        Astro.url.pathname.startsWith("/en")
          ? Astro.url.pathname
          : `/en${Astro.url.pathname === "/" ? "" : Astro.url.pathname}`,
        Astro.site
      ).toString()}
    />
    <link rel="alternate" hreflang="x-default" href={Astro.site!.toString()} />

    <!-- Privacy: no analytics, no third-party scripts, no Google Fonts -->
  </head>
  <body class="bg-paper text-ink min-h-screen flex flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-ink focus:text-paper focus:px-4 focus:py-2">
      {ui.nav.skipToContent}
    </a>

    <MagazineMasthead locale={locale} />
    <Nav locale={locale} />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer locale={locale} />
  </body>
</html>

<style>
  /* Tailwind's sr-only utility, inlined for the skip link */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .focus\:not-sr-only:focus {
    position: absolute;
    width: auto;
    height: auto;
    padding: revert;
    margin: revert;
    overflow: visible;
    clip: auto;
    white-space: normal;
  }
</style>
